# Firebase web SDK configuration
# Copy this file to `.env` and fill in values from your Firebase Console
# (Project settings → Your apps → Web app → SDK setup & configuration).
#
# These values are PUBLIC — they ship in the browser bundle. Security is
# enforced by Firestore & Storage Security Rules, not by hiding these keys.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Seed script only (never bundled into the client) ─────────────────────
# Used by `npm run seed` to authenticate as admin and write content to
# Firestore. The account must match the admin UID in firestore.rules.
ADMIN_EMAIL=
ADMIN_PASSWORD=
